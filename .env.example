# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack App-Level Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=xapp-your-app-token

# Slack Signing Secret
SLACK_SIGNING_SECRET=your-signing-secret

# Comma-separated Slack user IDs who can run setup/reset commands
ICEBREAKER_ADMIN_USER_IDS=U123ABC,U456DEF

# SQLite database path (relative or absolute)
DATABASE_PATH=./icebreaker.db

# Scheduler check interval in seconds (default: 30)
SCHEDULER_INTERVAL_SECONDS=30
